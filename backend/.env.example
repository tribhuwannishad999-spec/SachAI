# ====== SERVER ======
PORT=8080
NODE_ENV=production
# Comma separated list of allowed origins for CORS (your Vercel frontend URL)
CORS_ORIGIN=https://your-sachai-frontend.vercel.app,http://localhost:3000

# ====== AI PROVIDERS (priority order used automatically: 1 -> 2 -> 3 -> 4) ======
# 1. OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash
OPENROUTER_VISION_MODEL=google/gemini-3.5-flash

# 2. Gemini (Google AI Studio) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# 3. Groq — https://console.groq.com/keys
GROQ_API_KEY=
# Check https://console.groq.com/docs/models for currently supported (non-deprecated) model ids
GROQ_MODEL=openai/gpt-oss-20b

# 4. Hugging Face Inference Providers — https://huggingface.co/settings/tokens
HF_TOKEN=
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
HF_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct

# ====== CLOUDINARY (file storage for uploaded photos/videos/screenshots) ======
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ====== RAPIDAPI (used for phone-number spam lookup & domain/WHOIS lookup) ======
# Subscribe to a specific RapidAPI API (e.g. a phone-validator or whois API) and
# fill in the exact host + endpoint path it gives you — these vary by provider.
RAPIDAPI_KEY=
RAPIDAPI_PHONE_HOST=
RAPIDAPI_PHONE_ENDPOINT=
RAPIDAPI_WHOIS_HOST=
RAPIDAPI_WHOIS_ENDPOINT=

# ====== CACHE / RATE LIMIT ======
CACHE_TTL_SECONDS=1800
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=60

# ====== FUTURE (not used yet, reserved for V2 — admin/login/analytics) ======
JWT_SECRET=
DATABASE_URL=
